{
  "name": "tank-reconciliation-cap",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "passport": "^0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "@sap/cds-dk": "^10.0.3"
  },
  "scripts": {
    "start": "node node_modules/@sap/cds/bin/serve.js all --production",
    "test": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results.xml",
    "custom_build": "node build.js"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        },
        "[production]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        }
      },
      "auth": {
        "kind": "dummy",
        "[production]": {
          "kind": "xsuaa"
        }
      },
      "S4HANA": {
        "kind": "odata-v4",
        "credentials": {
          "destination": "S4HANA_PUBLIC_CLOUD",
          "requestTimeout": 30000
        },
        "[production]": {
          "credentials": {
            "destination": "S4HANA_PUBLIC_CLOUD",
            "requestTimeout": 30000
          }
        }
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
